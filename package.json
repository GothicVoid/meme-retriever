{
  "name": "tauri-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "tauri": "tauri",
    "package:models": "bash scripts/package-models.sh",
    "lint": "eslint src --ext .ts,.vue",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "lint-staged": {
    "*.{ts,vue}": "eslint"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-opener": "^2",
    "@vueuse/core": "^14.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.57.1",
    "vite": "^6.0.3",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^2.1.10"
  }
